      "parameters": {
        "jsCode": "const item = items[0].json;\nconst fields = item.body.data.fields;\n\nlet lead = {\n  name: fields.find(f => f.label === \"Full Name\")?.value ,\n  email: fields.find(f => f.label === \"Email\")?.value,\n  phone_number: fields.find(f => f.label === \"Phone Number\")?.value,\n  company: fields.find(f => f.label === \"Comapany\")?.value,\n  budget: fields.find(f => f.label === \"Budget\")?.value,\n  message: fields.find(f => f.label === \"Message\")?.value,\n}\n\nif (!lead.email) {\n  return [{\n    json: {\n      error: \"Missing email\"\n    }\n  }];\n}\n\nif (!lead.name) {\n  return [{\n    json: {\n      error: \"Missing name\"\n    }\n  }];\n}\n\nif (!lead.message) {\n  return [{\n    json: {\n      error: \"Missing message\"\n    }\n  }];\n}\n\nbudget: fields.find(f => f.label === \"Budget\")?.value ?? \"Not Provided\"\n\nreturn [{ json: lead }];"
      },
