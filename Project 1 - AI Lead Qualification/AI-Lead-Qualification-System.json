    {
      "parameters": {
        "jsCode": "const content = $input.first().json.content;\n\ntry {\n  const ai = JSON.parse(content);\n\n  const missing = [];\n\nif (ai.lead_score === undefined) missing.push(\"lead_score\");\nif (!ai.budget_score) missing.push(\"budget_score\");\nif (!ai.urgency) missing.push(\"urgency\");\nif (!ai.recommendation) missing.push(\"recommendation\");\nif (!ai.reason) missing.push(\"reason\");\nif (ai.confidence === undefined) missing.push(\"confidence\");\n\n  if (missing.length > 0) {\n  return [{\n    json: {\n      success: false,\n      error: `AI is missing: ${missing.join(\", \")}`\n    }\n  }];\n}\n\n  return [{\n    json: {\n      success: true,\n      ai\n    }\n  }];\n\n} catch (err) {\n\n  return [{\n    json: {\n      success: false,\n      error: err.message,\n      rawResponse: content\n    }\n  }];\n\n}"
      },
